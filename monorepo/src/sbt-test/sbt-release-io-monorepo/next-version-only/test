# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .
$ exec git commit -m "Initial commit"

# Release with only next-version override for core (no release-version override)
> releaseIOMonorepo core api with-defaults next-version core=9.9.9-SNAPSHOT

# Verify core got the override next version
> checkCoreVersion

# Verify api got computed next version
> checkApiVersion

# Verify core was tagged with computed release version
> checkCoreTags
