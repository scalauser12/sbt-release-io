# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit"

# Create an untracked file
$ touch untracked.txt

# Verify untracked file exists
$ exists untracked.txt

# Create a bare repository for pushing
$ delete ../test-remote.git
$ exec git init --bare ../test-remote.git
$ exec sh -c "git remote remove origin 2>/dev/null || true"
$ exec git remote add origin ../test-remote.git
$ exec git push -u origin main

# Release should succeed despite untracked file (because releaseIgnoreUntrackedFiles := true)
> releaseIO with-defaults release-version 0.1.0 next-version 0.2.0-SNAPSHOT

# Verify release completed
$ exec git tag | grep -q "v0.1.0"
