# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"

# Commit initial version.sbt with version already set to release version
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit with version 0.1.0"

# Run release with same version - should handle empty commit gracefully
> releaseIO with-defaults release-version 0.1.0 next-version 0.2.0-SNAPSHOT

# Verify tag was still created
$ exec sh -c "git tag | grep -q ."

# Verify final version is next version
$ exec grep -q "0.2.0-SNAPSHOT" version.sbt
