# Set up a minimal git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit"

# Delete any pre-existing marker file
$ delete action-ran

# Release must fail because the check phase raises an error
-> releaseIO with-defaults

# Marker must be absent: the check failed before any action ran
$ absent action-ran
