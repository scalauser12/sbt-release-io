$ exec git commit -m "Initial commit"

# Run each standalone release command in sequence; state flows between them
> release-vcs-checks

> release-check-snapshot-dependencies

> release-inquire-versions

> release-set-release-version

> release-commit-release-version

> release-tag-release

> release-set-next-version

> release-commit-next-version

# Verify release completed (default bump: 0.1.0 -> 0.1.1-SNAPSHOT)
> checkVersionSbt 0.1.1-SNAPSHOT
> checkGitCommitCount 3
> checkGitTag
