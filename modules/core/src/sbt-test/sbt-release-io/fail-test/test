# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt src/test/scala/FailTest.scala
$ exec git commit -m "Initial commit"

# Delete marker file if it exists
$ delete marker-file

# Try to release - should fail due to failing test and emit an attributed diagnostic
$ exec mkdir -p target
> writePluginVersion
$ exec sh -c 'mkdir -p target && sbt -Dsbt.log.noformat=true -batch releaseIO > target/release.log 2>&1; test $? -ne 0'
$ exec sh -c 'grep -q "Release failed: run-tests:" target/release.log || { cat target/release.log; exit 1; }'
$ exec sh -c 'grep -q "FailureCommand" target/release.log'

# Verify marker file was NOT created (because release failed before reaching createFile step)
$ absent marker-file
