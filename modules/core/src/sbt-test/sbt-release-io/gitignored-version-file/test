# Initialize a git repo where version.sbt is matched by .gitignore.
# `untrackedFiles` (`git ls-files --other --exclude-standard`) does NOT report
# ignored files, so without the explicit isIgnored probe the release would
# silently no-op the version commit and tag the pre-release HEAD.
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt project/plugins.sbt
$ exec git commit -m "Initial commit (version.sbt deliberately gitignored)"

# Sanity: version.sbt is on disk but matched by .gitignore.
$ exists version.sbt

# `releaseIO check` must fail at validate time — before any disk mutation.
-> releaseIO check

# Even after a failed validate, version.sbt must be untouched.
> checkVersionFileUnchanged

# A full release must also abort, and (critically) abort BEFORE
# set-release-version rewrites the file. Otherwise a retry would compute
# next-version from the corrupted "release version" still sitting on disk.
-> releaseIO with-defaults release-version 0.1.0 next-version 0.2.0-SNAPSHOT

# Post-abort invariants:
# 1. version.sbt content is unchanged (no mid-flight rewrite leaked through).
> checkVersionFileUnchanged
# 2. version.sbt remains untracked (no surprise force-add behind user's back).
> checkVersionFileStillIgnored
# 3. No release tag was created.
> checkNoReleaseTag
