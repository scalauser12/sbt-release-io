# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add build.sbt version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit"

# Stage the external version file outside the repo so the validate-time check
# has something to read (existence check passes; path-within-VCS check should fail).
> createExternalFile

# `releaseIO check` must fail at validate, not silently mutate the external file.
-> releaseIO check with-defaults release-version 0.1.0 next-version 0.2.0-SNAPSHOT

# A real release should also fail at the same point; verify the external file is
# untouched.
-> releaseIO with-defaults release-version 0.1.0 next-version 0.2.0-SNAPSHOT

> checkExternalFileUntouched
