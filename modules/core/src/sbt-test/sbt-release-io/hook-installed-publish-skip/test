# Regression: a `beforePublish` hook that installs `publish/skip := true`
# via `appendWithSession` must be observed by the publish task. Strategy B
# moved persistent release overlays into `session.rawAppend`; any
# structure-rebuilding step downstream of the hook must not drop
# hook-installed settings.
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit"

# Release; the before-publish hook sets publish/skip := true.
> releaseIO with-defaults release-version 0.1.0 next-version 0.2.0-SNAPSHOT

# Assert the publish task observed the hook-installed skip = true.
> checkPublishSkipped
