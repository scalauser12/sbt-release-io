# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit"

# Verify VCS checks pass on a clean working directory
> release-vcs-checks

# Run a full release to verify extra commands are registered and the flow works
> 'releaseIO with-defaults release-version 1.0.0-RC1 next-version 1.0.0-RC2-SNAPSHOT'

# Verify the release completed (initial + release commit + next commit = 3)
> checkVersionSbt 1.0.0-RC2-SNAPSHOT
> checkGitCommitCount 3
> checkTagExists v1.0.0-RC1
