# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt version.properties project/plugins.sbt
$ exec git commit -m "Initial commit"

# Run release through the hook-based late-bound flow
> releaseIO with-defaults release-version 0.1.0 next-version 0.2.0-SNAPSHOT

# Verify the late-bound settings were applied at runtime
$ exists late-bound-version-settings-ran
$ exists late-bound-tag-settings-ran
> checkRuntimeVersionFile
> checkLateBoundTag
