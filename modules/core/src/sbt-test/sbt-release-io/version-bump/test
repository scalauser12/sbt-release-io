# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit"

# SCENARIO 1: Default (Next) bump strategy
# Starting version: 1.0.0-RC1-SNAPSHOT
# Expected release: 1.0.0-RC1, next: 1.0.0-RC2-SNAPSHOT
> releaseIO with-defaults default-tag-exists-answer o
> checkVersionSbt 1.0.0-RC2-SNAPSHOT

# Reset to release version commit and verify it was set correctly
$ exec git reset --hard HEAD~1
$ exec grep -q '"1.0.0-RC1"' version.sbt

# Reset to initial commit to test other strategies
$ exec git reset --hard HEAD~1
$ exec grep -q '"1.0.0-RC1-SNAPSHOT"' version.sbt
> reload

# SCENARIO 2: NextStable bump strategy
# Starting version: 1.0.0-RC1-SNAPSHOT
# Expected release: 1.0.0 (qualifier stripped by NextStable), next: 1.0.1-SNAPSHOT
> set releaseVersionBump := sbtrelease.Version.Bump.NextStable
> releaseIO with-defaults default-tag-exists-answer o
> checkVersionSbt 1.0.1-SNAPSHOT

# Reset to release version commit and verify (qualifier stripped -> 1.0.0)
$ exec git reset --hard HEAD~1
$ exec grep -q '"1.0.0"' version.sbt

# Reset to initial commit
$ exec git reset --hard HEAD~1
$ exec grep -q '"1.0.0-RC1-SNAPSHOT"' version.sbt
> reload

# SCENARIO 3: Bugfix bump strategy
# Starting version: 1.0.0-RC1-SNAPSHOT
# Expected release: 1.0.0 (qualifier stripped by Bugfix), next: 1.0.1-SNAPSHOT
> set releaseVersionBump := sbtrelease.Version.Bump.Bugfix
> releaseIO with-defaults default-tag-exists-answer o
> checkVersionSbt 1.0.1-SNAPSHOT

# Reset to release version commit and verify (qualifier stripped -> 1.0.0)
$ exec git reset --hard HEAD~1
$ exec grep -q '"1.0.0"' version.sbt

# Reset to initial commit
$ exec git reset --hard HEAD~1
$ exec grep -q '"1.0.0-RC1-SNAPSHOT"' version.sbt
> reload

# SCENARIO 4: Minor bump strategy
# Expected release: 1.0.0 (qualifier stripped by Minor), next: 1.1.0-SNAPSHOT
> set releaseVersionBump := sbtrelease.Version.Bump.Minor
> releaseIO with-defaults default-tag-exists-answer o
> checkVersionSbt 1.1.0-SNAPSHOT

# Reset to release version commit and verify (qualifier stripped -> 1.0.0)
$ exec git reset --hard HEAD~1
$ exec grep -q '"1.0.0"' version.sbt
