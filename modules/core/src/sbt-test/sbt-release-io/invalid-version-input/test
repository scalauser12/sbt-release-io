# Test: Invalid CLI version strings are rejected
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .
$ exec git commit -m "Initial commit"

# Invalid release-version should fail
-> releaseIO with-defaults release-version banana next-version 0.2.0-SNAPSHOT
> checkNoGitTags
> checkVersionUnchanged

# Invalid next-version should also fail
-> releaseIO with-defaults release-version 0.1.0 next-version banana
> checkNoGitTags
> checkVersionUnchanged
