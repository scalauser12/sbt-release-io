# Initialize a local repo and stage the project files.
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit"
$ exec git branch -M main

# Set up a bare remote with `remote.origin.tagOpt = --no-tags` so the local repo
# never auto-fetches the divergent remote tag created below — the precondition
# that makes the keep decision (taken from local refs only) blind to the remote.
$ exec mkdir remotes
$ exec git init --bare remotes/origin.git
$ exec git remote add origin remotes/origin.git
$ exec git config remote.origin.tagOpt --no-tags
$ exec git push -u origin main

# Push v0.1.0 to the remote at a DIFFERENT commit, via a separate clone with an
# extra commit. This mirrors a collaborator/CI having moved or re-created the tag.
$ exec git clone remotes/origin.git temp-clone
$ exec git -C temp-clone config user.email "other@example.com"
$ exec git -C temp-clone config user.name "Other Author"
$ exec git -C temp-clone commit --allow-empty -m "divergent commit"
$ exec git -C temp-clone tag -a v0.1.0 -m "remote tag"
$ exec git -C temp-clone push origin v0.1.0

# Create the local tag at the local HEAD. version.sbt already equals the release
# version 0.1.0, so the release writes no new commit and the tag MATCHES the
# release commit — keep is accepted locally.
$ exec git tag -a v0.1.0 -m "local tag"
$ exec git rev-parse --verify refs/tags/v0.1.0

# Keep the existing tag (k). Local matches, but the remote holds v0.1.0 at a
# different commit, so the hash-aware keep probe MUST abort at tag-preflight —
# before set-release-version, the release commit, or publish.
-> releaseIO with-defaults default-tag-exists-answer k release-version 0.1.0 next-version 0.2.0-SNAPSHOT

# Verify nothing was written: version file unchanged, no extra commits.
> checkKeepDivergenceAborted
