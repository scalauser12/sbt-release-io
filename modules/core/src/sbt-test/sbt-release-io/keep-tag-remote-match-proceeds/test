# Initialize a local repo and stage the project files.
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit"
$ exec git branch -M main

# Set up a bare remote. Create the annotated tag locally and push it so the
# remote holds v0.1.0 at the SAME commit the release will keep.
$ exec mkdir remotes
$ exec git init --bare remotes/origin.git
$ exec git remote add origin remotes/origin.git
$ exec git tag -a v0.1.0 -m "release"
$ exec git push -u origin main
$ exec git push origin v0.1.0

# Keep the existing tag (k). The local tag matches the release commit AND the
# remote holds the same annotated tag at the same commit, so the keep probe must
# NOT abort — the release runs to completion (next version written, tag kept).
> releaseIO with-defaults default-tag-exists-answer k release-version 0.1.0 next-version 0.2.0-SNAPSHOT

> checkReleaseProceeded
