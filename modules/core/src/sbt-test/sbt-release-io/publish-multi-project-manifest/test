# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt libA libB
$ exec git commit -m "Initial commit"

# Run release: aggregated publish must propagate Vcs-Release-Hash / Vcs-Release-Tag to children
> releaseIO with-defaults release-version 0.1.0 next-version 0.2.0-SNAPSHOT

# Verify the version bump
$ exec grep -q "0.2.0-SNAPSHOT" version.sbt

# Verify each child JAR has the expected manifest entries
> checkChildManifests

# Verify the release-only metadata is cleaned from session packageOptions after release
> checkSessionCleaned
