# Initialize git repository - version already at release (0.1.0) would fail at inquire
# (sbt-release requires snapshot). Instead verify release flow when version file
# transitions SNAPSHOT -> release -> next SNAPSHOT (same as empty-commit).
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit"

# Run release - commitReleaseVersion skips when status empty (VersionSteps lines 207-215)
> releaseIO with-defaults release-version 0.1.0 next-version 0.2.0-SNAPSHOT

# Verify next version written
$ exec grep -q "0.2.0-SNAPSHOT" version.sbt

# Verify release completed
> checkGitCommitCount 3
> checkGitTag
