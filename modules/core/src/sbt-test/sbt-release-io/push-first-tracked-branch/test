# Test: push-changes creates the tracked remote branch on the first push
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit"
$ exec git branch -M main

# Set up a bare remote and tracking config without creating origin/main first
$ exec mkdir remotes
$ exec git init --bare remotes/origin.git
$ exec git remote add origin remotes/origin.git
$ exec git config branch.main.remote origin
$ exec git config branch.main.merge refs/heads/main

# Run release with push-changes enabled; the first push should create origin/main
> releaseIO with-defaults release-version 0.1.0 next-version 0.2.0-SNAPSHOT

# Verify branch and tag were pushed to origin
> checkPushed

# Verify version was bumped locally
$ exec grep -q "0.2.0-SNAPSHOT" version.sbt
