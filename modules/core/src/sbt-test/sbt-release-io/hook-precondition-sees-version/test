# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit"

# Validation-only must succeed: post-version-resolution preconditions see tentative versions.
> releaseIO check release-version 0.1.0 next-version 0.2.0-SNAPSHOT

# Real release also exercises the same validate prefix and must succeed.
> releaseIO with-defaults release-version 0.1.0 next-version 0.2.0-SNAPSHOT

# Verify release completed
$ exec grep -q "0.2.0-SNAPSHOT" version.sbt

# Verify the beforeVersionResolution execute hook saw `None` for both versions.
# This locks the validate→execute boundary clearance: validate-time tentative seeds
# must not bleed into the execute-time view of pre-resolution hooks.
$ exec grep -qF release=None target/before-version-resolution-execute.txt
$ exec grep -qF next=None target/before-version-resolution-execute.txt
