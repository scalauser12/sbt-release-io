# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt version.sbt project/plugins.sbt src
$ exec git commit -m "Initial commit"

# Run release - process has only stepCommandAndRemaining("compileAndMark")
> releaseIO with-defaults

# Verify compile drained and the follow-up marker command ran
$ exists marker/compile-ran
