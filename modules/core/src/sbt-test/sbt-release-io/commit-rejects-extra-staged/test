# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add build.sbt version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit"

# A hook between set-release-version and commit-release-version stages an unrelated
# file. The release must fail before tagging so the unrelated change cannot ride along
# silently in the release commit.
-> releaseIO with-defaults release-version 0.1.0 next-version 0.2.0-SNAPSHOT

> checkNoReleaseTag
> checkInitialHeadOnly
