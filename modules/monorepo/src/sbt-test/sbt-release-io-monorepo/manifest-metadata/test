# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt core/version.sbt api/version.sbt project/plugins.sbt
$ exec git commit -m "Initial commit"

# Run the release with publish enabled and push disabled
> releaseIOMonorepo core api with-defaults release-version core=0.1.0 next-version core=0.2.0-SNAPSHOT release-version api=0.1.0 next-version api=0.2.0-SNAPSHOT

# Verify manifest metadata on the published jars and that the sbt session was cleaned
> checkPublishedMetadata
> checkVisibleMetadata
> checkSessionCleaned
