# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .
$ exec git commit -m "Initial commit"

# Run monorepo release with global version overrides
> releaseIOMonorepo core api with-defaults release-version 1.0.0 next-version 1.1.0-SNAPSHOT

# Verify global version file was updated to next version
> checkGlobalVersionFile

# Verify per-project tags were created
> checkGitTags
