# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .
$ exec git commit -m "Initial commit"

# Simulate a previous unified release by creating a unified tag
$ exec git tag v0.1.0

# Modify ONLY core directory (add a file and commit)
$ exec touch core/CHANGES.md
$ exec git add core/CHANGES.md
$ exec git commit -m "Add changes file to core"

# Release with NO explicit project selection — relies on change detection.
# With unified tags, detection should match v* pattern and find v0.1.0.
# Only core has changes since v0.1.0, so only core should be released.
# Note: no api overrides — providing them would force-include api in the release.
> releaseIOMonorepo with-defaults release-version core=0.2.0 next-version core=0.2.1-SNAPSHOT

# Verify unified tags, core next version, and api version unchanged
> checkAll
