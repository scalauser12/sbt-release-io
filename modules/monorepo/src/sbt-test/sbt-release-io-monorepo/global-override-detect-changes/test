# Test: global version override forces all projects in detect-changes mode
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .
$ exec git commit -m "Initial commit"

# Simulate a previous release by creating tags for both projects
$ exec git tag core/v1.0.0
$ exec git tag api/v1.0.0

# NO file changes since the tags — change detection would normally find nothing.
# But a global version override signals intent to release all projects.
> releaseIOMonorepo with-defaults release-version 2.0.0 next-version 2.1.0-SNAPSHOT

# Verify both projects were released despite no detected changes
> checkAll
