# Initialize a local repo, stage project files, and create the local
# core/v0.1.0 tag (the original tag for the configured release version 0.1.0).
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt project/plugins.sbt core/version.sbt api/version.sbt
$ exec git commit -m "Initial commit"
$ exec git branch -M main
$ exec git tag core/v0.1.0

# Set up a bare remote with `tagOpt = --no-tags` so the warmup fetch does not
# auto-pull the conflicting tag.
$ exec mkdir remotes
$ exec git init --bare remotes/origin.git
$ exec git remote add origin remotes/origin.git
$ exec git config remote.origin.tagOpt --no-tags
$ exec git push -u origin main
$ exec git push origin core/v0.1.0

# Create the conflicting REPLACEMENT tag (core/v0.2.0) on the remote only.
$ exec git clone remotes/origin.git temp-clone
$ exec git -C temp-clone config user.email "other@example.com"
$ exec git -C temp-clone config user.name "Other Author"
$ exec git -C temp-clone tag core/v0.2.0
$ exec git -C temp-clone push origin core/v0.2.0

# Confirm the local repo does NOT have core/v0.2.0.
-$ exec git rev-parse --verify --quiet refs/tags/core/v0.2.0

# Run the release with `default-tag-exists-answer core/v0.2.0`. The local
# preflight sees core/v0.1.0 already exists locally and follows the retry
# answer, picking core/v0.2.0 as the final tag name. core/v0.2.0 does NOT
# exist locally but DOES exist on the remote — the release MUST abort at
# `tag-preflight` before any side effect.
-> releaseIOMonorepo core api with-defaults default-tag-exists-answer core/v0.2.0 release-version core=0.1.0 next-version core=0.3.0-SNAPSHOT release-version api=0.1.0 next-version api=0.3.0-SNAPSHOT

# Verify nothing happened on the local side.
> checkNoReleaseSideEffects
