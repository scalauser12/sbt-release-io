# Initialize a local repo and stage project files.
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .gitignore build.sbt project/plugins.sbt core/version.sbt api/version.sbt
$ exec git commit -m "Initial commit"
$ exec git branch -M main

# Set up a bare remote with `tagOpt = --no-tags` so the warmup fetch does not
# auto-pull the divergent per-project tag created on the remote below.
$ exec mkdir remotes
$ exec git init --bare remotes/origin.git
$ exec git remote add origin remotes/origin.git
$ exec git config remote.origin.tagOpt --no-tags
$ exec git push -u origin main

# Push core/v0.1.0 to the remote at a DIFFERENT commit, via a separate clone.
$ exec git clone remotes/origin.git temp-clone
$ exec git -C temp-clone config user.email "other@example.com"
$ exec git -C temp-clone config user.name "Other Author"
$ exec git -C temp-clone commit --allow-empty -m "divergent commit"
$ exec git -C temp-clone tag -a core/v0.1.0 -m "remote tag"
$ exec git -C temp-clone push origin core/v0.1.0

# Create the local per-project tag at the local HEAD. core/version.sbt already
# equals the release version 0.1.0, so the release writes no new commit and the
# tag MATCHES the release commit — keep is accepted locally.
$ exec git tag -a core/v0.1.0 -m "local tag"
$ exec git rev-parse --verify refs/tags/core/v0.1.0

# Keep the existing tag (k). Local matches, but the remote holds core/v0.1.0 at a
# different commit, so the hash-aware keep probe MUST abort at tag-preflight —
# before set-release-versions, the release commit, or publish.
-> releaseIOMonorepo core with-defaults default-tag-exists-answer k release-version core=0.1.0 next-version core=0.2.0-SNAPSHOT

# Verify nothing was written: core's version file unchanged, no extra commits.
> checkKeepDivergenceAborted
