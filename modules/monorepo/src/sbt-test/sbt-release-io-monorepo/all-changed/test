# Test: all-changed CLI flag releases all projects bypassing change detection
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .
$ exec git commit -m "Initial commit"

# Simulate a previous release by manually creating tags
$ exec git tag core/v0.1.0
$ exec git tag api/v0.1.0

# Modify ONLY core directory (add a file and commit)
$ exec touch core/CHANGES.md
$ exec git add core/CHANGES.md
$ exec git commit -m "Add changes file to core"

# Release with all-changed flag — should release BOTH core and api,
# even though only core has changes since its last tag.
> releaseIOMonorepo all-changed with-defaults release-version core=0.2.0 next-version core=0.3.0-SNAPSHOT release-version api=0.2.0 next-version api=0.3.0-SNAPSHOT

# Verify BOTH core/v0.2.0 and api/v0.2.0 tags were created
> checkTags
> checkCoreVersion
> checkApiVersion
