# Test: untracked files abort release when releaseIgnoreUntrackedFiles=false
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .
$ exec git commit -m "Initial commit"

# Create an untracked file (not git-added)
$ exec touch untracked-file.txt

# Release should fail in check phase because untracked files are present
-> releaseIOMonorepo core with-defaults release-version core=0.1.0 next-version core=0.2.0-SNAPSHOT
> checkFailureArtifacts
