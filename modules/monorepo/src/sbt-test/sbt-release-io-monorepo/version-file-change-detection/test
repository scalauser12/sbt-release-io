# Initialize git repository
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .
$ exec git commit -m "Initial commit"

# Simulate a previous release: tag at release version (0.1.0)
$ exec git tag core/v0.1.0
$ exec git tag api/v0.1.0

# Simulate what commitNextVersions does after a release:
# modify ONLY core/version.sbt from "0.1.0" to "0.2.0-SNAPSHOT"
$ copy-file changes/core-version.sbt core/version.sbt
$ exec git add core/version.sbt
$ exec git commit -m "Setting next version: core 0.2.0-SNAPSHOT"

# Release should FAIL because only version files changed — no real changes detected.
# The -> prefix expects the command to fail.
-> releaseIOMonorepo with-defaults release-version core=0.2.0 next-version core=0.3.0-SNAPSHOT
