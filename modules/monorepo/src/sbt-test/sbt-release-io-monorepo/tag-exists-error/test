# --- Scenario A: with-defaults (useDefaults path in createTag) ---
$ exec git init
$ exec git config user.email "test@example.com"
$ exec git config user.name "Test User"
$ exec git add .
$ exec git commit -m "Initial commit"

$ exec git tag core/v1.0.0

-> releaseIOMonorepo core api with-defaults release-version core=1.0.0 next-version core=1.1.0-SNAPSHOT release-version api=1.0.0 next-version api=1.1.0-SNAPSHOT

> checkAll

# --- Scenario B: non-interactive default (no with-defaults; !ctx.interactive in createTag) ---
$ exec sh -c 'git reset --hard "$(git rev-list --max-parents=0 HEAD)"'
$ exec sh -c 'git tag -d api/v1.0.0 2>/dev/null || true'

-> releaseIOMonorepo core api release-version core=1.0.0 next-version core=1.1.0-SNAPSHOT release-version api=1.0.0 next-version api=1.1.0-SNAPSHOT

